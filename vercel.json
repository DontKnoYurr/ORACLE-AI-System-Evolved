{
  "version": 2,
  "buildCommand": "cd Code-Feature-Evolve/artifacts/oracle && pnpm install && pnpm build",
  "outputDirectory": "Code-Feature-Evolve/artifacts/oracle/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/oracle",
      "destination": "/",
      "permanent": false
    },
    {
      "source": "/control",
      "destination": "/integrated-control-center",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "destination": "/integrated-control-center",
      "permanent": false
    }
  ]
}
